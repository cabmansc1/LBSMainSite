# --- Secrets: never commit ---
# NOTE: config.php IS committed (private repo). It holds only client-exposed
# keys (Google Maps, reCAPTCHA site key); the DB password lives in the separate
# secure/db_config.php (cPanel) or in environment variables (Railway).
.env
.env.*
*_config.php.bak

# --- User-uploaded content (98MB of photos; back up separately) ---
uploads/

# --- Composer installer artifacts (kept vendor/, but not these) ---
composer.phar
composer-setup.php

# --- Logs ---
*.log
error_log
php-errors.log

# --- OS / editor junk ---
.DS_Store
Thumbs.db
*.swp
*~

# --- Empty/stray ---
public_html/

# --- Composer dependencies (restore with: composer install) ---
vendor/

# temporary uploads seed archive (not for git)
_seed_uploads_*.tgz
